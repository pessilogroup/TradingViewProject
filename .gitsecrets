# ════════════════════════════════════════════════════════════════
# .gitsecrets — git-secrets prohibited patterns
# Ngăn commit vô tình chứa secrets/API keys
#
# Setup:
#   # Install git-secrets (Mac)
#   brew install git-secrets
#
#   # Install git-secrets (Linux/Windows)
#   git clone https://github.com/awslabs/git-secrets ~/.git-secrets
#   cd ~/.git-secrets && sudo make install
#
#   # Register patterns vào repo này
#   git secrets --add-provider -- cat .gitsecrets
#   git secrets --install   # cài pre-commit, commit-msg, prepare-commit-msg hooks
#
# Test (phải bị chặn):
#   echo "sk-ant-api03-test" | git secrets --scan -
# ════════════════════════════════════════════════════════════════

# ── Anthropic API Keys ──────────────────────────────────────────
sk-ant-api03-[A-Za-z0-9\-_]{90,}

# ── Google / Gemini API Keys ────────────────────────────────────
AIza[0-9A-Za-z\-_]{35}

# ── Binance API Keys (typically 64 hex chars) ──────────────────
[A-Za-z0-9]{64}(?=.*[A-Za-z])(?=.*[0-9])

# ── Generic Secret-like patterns ───────────────────────────────
# Token hex 32+ chars (Python secrets.token_hex)
(?i)secret[\"']?\s*[:=]\s*[\"']?[a-f0-9]{32,}

# Bearer tokens
(?i)bearer\s+[a-zA-Z0-9\-_\.]{20,}

# Private keys
-----BEGIN (RSA|EC|OPENSSH) PRIVATE KEY-----

# ── Tailscale Auth Keys ─────────────────────────────────────────
tskey-auth-[A-Za-z0-9\-_]{30,}
tskey-[A-Za-z0-9\-_]{30,}

# ── Telegram Bot Token ──────────────────────────────────────────
[0-9]{8,10}:AA[A-Za-z0-9\-_]{33}

# ── UptimeRobot ─────────────────────────────────────────────────
ur[0-9]+-[a-zA-Z0-9]{32,}

# ── Webhook Secrets ─────────────────────────────────────────────
(?i)webhook[_-]?secret[\"']?\s*[:=]\s*[\"']?[a-f0-9]{32,}

# ── Known allowlisted values (false positives) ──────────────────
# Thêm vào git-secrets allowed list, không phải vào file này:
#   git secrets --add --allowed "token_hex\(32\)"
