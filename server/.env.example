# =========================================================
# TradingView Webhook Server — Environment Configuration
# =========================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git (already in .gitignore)
# =========================================================

# Server
HOST=0.0.0.0
PORT=5000
DEBUG=true
LOG_FILE=trades.log

# Database (Sprint 4)
DB_PATH=trades.db

# Security
WEBHOOK_SECRET=change_me_to_a_strong_random_secret
ENABLE_IP_WHITELIST=false

# Binance API (Optional — leave blank to receive signals only)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord Webhook (optional)
DISCORD_WEBHOOK_URL=