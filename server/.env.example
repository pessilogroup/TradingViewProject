# ── Server ───────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=5000
DEBUG=false

# ── Security ──────────────────────────────────────────────────────────────
WEBHOOK_SECRET=change_me_in_production

# ── Database ──────────────────────────────────────────────────────────────
DB_PATH=trades.db
LOG_FILE=trades.log

# ── Binance API (optional) ────────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
BINANCE_DRY_RUN=true

# ── Risk Management (Sprint 7.2 — Minervini SEPA) ────────────────────────
# Mỗi lệnh risk tối đa % account balance
RISK_PER_TRADE=0.02
# Stop-loss mặc định 8% (Minervini rule)
STOP_LOSS_PCT=0.08
# Take-profit mặc định 20% (R:R ≥ 2.5:1)
TAKE_PROFIT_PCT=0.20

# ── Notifications ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# ── TradingView IP Whitelist ──────────────────────────────────────────────
ENABLE_IP_WHITELIST=false

# ── RAG / Knowledge Base (P5) ────────────────────────────────────────────
# ANTHROPIC_API_KEY: Lấy tại https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bật / tắt RAG (nếu chưa có API key thì để false)
RAG_ENABLED=true

# Số chunks context tối đa trả về cho mỗi query (khuyến nghị: 3)
RAG_TOP_K=3

# Đường dẫn tới thư mục chunks (để trống = tự động detect)
# KNOWLEDGE_DIR=../docs/knowledge/trading_wizard/chunks

# Đường dẫn lưu ChromaDB (để trống = ./chroma_db bên trong server/)
# CHROMA_DB_PATH=./chroma_db

# ── MCP / Morning Brief (P6) ─────────────────────────────────────────────────
# Kích hoạt TradingView MCP (cần TradingView Desktop đang chạy)
MCP_ENABLED=false

# CDP port (TradingView Desktop phải launch với --remote-debugging-port=9222)
MCP_CDP_PORT=9222

# Node.js path (để trống nếu node đã trong PATH)
# MCP_NODE_PATH=node

# Bật Morning Brief tự động hàng ngày
BRIEF_ENABLED=false

# Giờ chạy Morning Brief (HH:MM, UTC+7 ICT)
BRIEF_CRON_TIME=07:00

# Watchlist mặc định (comma-separated, sẽ bị override bởi watchlist.json)
WATCHLIST_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# === P7: Telegram Bot Interactive ===
# Bật/tắt interactive Telegram bot (commands: /brief, /scan, /watchlist, etc.)
# Bot chạy song song với FastAPI server (polling mode trong background thread)
TELEGRAM_BOT_ENABLED=false
