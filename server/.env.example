# =========================================================
# TradingView Webhook Server — Environment Configuration
# =========================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git (already in .gitignore)
# =========================================================

# Server
HOST=0.0.0.0
PORT=5000
DEBUG=true
LOG_FILE=trades.log

# Security — set a strong random secret and use the SAME
# value in TradingView Alert JSON payload as "secret": "..."
WEBHOOK_SECRET=change_me_to_a_strong_random_secret

# Enable TradingView IP whitelisting (recommended for Production)
# Set false when testing locally with curl/Postman
ENABLE_IP_WHITELIST=false

# Binance API (Optional — leave blank to receive signals only)
# Get keys: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=
BINANCE_API_SECRET=
# true = Testnet (safe), false = Live (real money!)
BINANCE_TESTNET=true

# Telegram Bot
# 1. Talk to @BotFather on Telegram to create a bot
# 2. Get Chat ID by messaging @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord Webhook (optional, leave blank to disable)
DISCORD_WEBHOOK_URL=