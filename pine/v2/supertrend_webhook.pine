//@version=6
// ============================================================================
// SuperTrend Flip — Webhook Alert for VBS Pipeline
// ============================================================================
// V1.2: + Market Regime Filter (EMA200 + ADX) + SL 1.5x adaptive
//       + Walk-Forward optimized: Period=7, Mult=3.0, RSI=ON, Vol=OFF
// ============================================================================
indicator("SuperTrend Flip Webhook", overlay=true, max_labels_count=50)

import dinhvietdan88/VBS_Webhook_Lib/3 as vbs

// ═══════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════
grp_core = "Core Settings"
webhookSecret   = input.string("7086c59c523e87c90f9d56db63a66fd9045cb081264afe65c4ce8c37cff89104", "Webhook Secret", group=grp_core)
confidenceScore = input.int(80, "Base Confidence (%)", minval=0, maxval=100, group=grp_core)

grp_st = "SuperTrend Settings"
stPeriod = input.int(7,    "ATR Period",     minval=1, maxval=50,   group=grp_st)   // 3-Month WF: Mar+Apr+May 2026
stMult   = input.float(3.5, "ATR Multiplier", minval=0.5, maxval=10.0, step=0.1, group=grp_st)  // WF: 3.5
slMult   = input.float(1.5, "SL ATR Mult",   minval=0.5, maxval=5.0,  step=0.1, group=grp_st)  // WF: 1.5x
rrr      = input.float(2.0, "Risk/Reward",   minval=1.0, maxval=10.0, step=0.5, group=grp_st)  // WF: 2.0

grp_regime = "Market Regime Filter"
useRegimeFilter = input.bool(true,  "Regime Filter (EMA200 + ADX)", group=grp_regime)
emaLen          = input.int(200,    "Trend EMA Length",             group=grp_regime)
adxLen          = input.int(14,     "ADX Length",                   group=grp_regime)
adxThresh       = input.int(20,     "Min ADX (trending)",           group=grp_regime, minval=10, maxval=50)
longOnly        = input.bool(false, "Long Only Mode",               group=grp_regime)

grp_filter = "Confirmation Filters"
useVolumeFilter = input.bool(false, "Volume > SMA(20) Filter", group=grp_filter)  // OFF: hurts long-term WR
useRsiFilter    = input.bool(true,  "RSI Zone Filter (30-70)", group=grp_filter)  // ON: key filter

grp_vis = "Visual Settings"
bullColor  = input.color(#00c853, "Bull Color",     group=grp_vis)
bearColor  = input.color(#ff1744, "Bear Color",     group=grp_vis)
showLabels = input.bool(true,     "Show Flip Labels", group=grp_vis)
showRegime = input.bool(true,     "Show Regime EMA",  group=grp_vis)

// ═══════════════════════════════════════════════════════════════
// SUPERTREND + INDICATORS
// ═══════════════════════════════════════════════════════════════
[stValue, stDir] = ta.supertrend(stMult, stPeriod)

bullFlip = ta.change(stDir) < 0 and barstate.isconfirmed
bearFlip = ta.change(stDir) > 0 and barstate.isconfirmed

atrVal = ta.atr(14)
rsiVal = ta.rsi(close, 14)
volSma = ta.sma(volume, 20)

// ── Market Regime Filter ──────────────────────────────────────
ema200    = ta.ema(close, emaLen)
[diPlus, diMinus, adxVal] = ta.dmi(adxLen, adxLen)

isTrending  = adxVal > adxThresh
isUptrend   = close > ema200
isDowntrend = close < ema200

regimeOkLong  = not useRegimeFilter or (isTrending and isUptrend)
regimeOkShort = not useRegimeFilter or (isTrending and isDowntrend and not longOnly)

// ── Other Filters ─────────────────────────────────────────────
volOk      = not useVolumeFilter or vbs.volume_confirmed(20)
volRatio   = vbs.volume_ratio(20)
rsiOkLong  = not useRsiFilter or (rsiVal < 70)
rsiOkShort = not useRsiFilter or (rsiVal > 30)

// ── Final Signals ─────────────────────────────────────────────
longSignal  = bullFlip and volOk and rsiOkLong  and regimeOkLong
shortSignal = bearFlip and volOk and rsiOkShort and regimeOkShort

// ═══════════════════════════════════════════════════════════════
// SL / TP CALCULATION (adaptive: SL=1.5x ATR, TP=RRR*SL)
// ═══════════════════════════════════════════════════════════════
slDist   = slMult * atrVal
tpDistL  = rrr * slDist
tpDistS  = rrr * slDist

slLong   = close - slDist
tpLong   = close + tpDistL
slShort  = close + slDist
tpShort  = close - tpDistS
trlStop  = close - 1.5 * atrVal   // Trail stop for long reference

// ═══════════════════════════════════════════════════════════════
// CONFIDENCE SCORING (via library)
// ═══════════════════════════════════════════════════════════════
longConf  = vbs.calc_confidence(confidenceScore, rsiVal, volume, volSma, true)
shortConf = vbs.calc_confidence(confidenceScore, rsiVal, volume, volSma, false)

// ═══════════════════════════════════════════════════════════════
// PAYLOAD BUILDER (via library)
// ═══════════════════════════════════════════════════════════════
buildMeta(dir, sl, tp, trail) =>
    vbs.meta_join5(
         vbs.meta_str("direction", dir),
         vbs.meta_float("atr_value",   atrVal),
         vbs.meta_float("sl",          sl),
         vbs.meta_float("tp",          tp),
         vbs.meta_float("trail_stop",  trail)
     )

// ═══════════════════════════════════════════════════════════════
// ALERT DISPATCH
// ═══════════════════════════════════════════════════════════════
if longSignal
    alert(vbs.build_payload(webhookSecret, "SuperTrend Flip", syminfo.ticker,
         "buy", "entry", "long", close, timeframe.period, syminfo.prefix,
         longConf, buildMeta("long", slLong, tpLong, trlStop)),
         alert.freq_once_per_bar_close)

if shortSignal
    alert(vbs.build_payload(webhookSecret, "SuperTrend Flip", syminfo.ticker,
         "sell", "entry", "short", close, timeframe.period, syminfo.prefix,
         shortConf, buildMeta("short", slShort, tpShort, float(na))),
         alert.freq_once_per_bar_close)

alertcondition(longSignal,  title="SuperTrend Bull Flip", message="ST BULL")
alertcondition(shortSignal, title="SuperTrend Bear Flip", message="ST BEAR")

// ═══════════════════════════════════════════════════════════════
// VISUALIZATION
// ═══════════════════════════════════════════════════════════════
stColor = stDir < 0 ? bullColor : bearColor
plot(stValue, "SuperTrend", color=color.new(stColor, 0), linewidth=2, style=plot.style_linebr)

// Regime EMA
emaColor = isUptrend ? color.new(bullColor, 40) : color.new(bearColor, 40)
plot(showRegime ? ema200 : na, "EMA200", color=emaColor, linewidth=1, style=plot.style_line)

pClose = plot(close, display=display.none)
pST    = plot(stValue, display=display.none)

// Fill: dim when regime filter blocks
fillAlpha = (useRegimeFilter and not isTrending) ? 97 : 90
fill(pClose, pST, color=stDir < 0 ? color.new(bullColor, fillAlpha) : color.new(bearColor, fillAlpha), title="ST Fill")

plotshape(showLabels and longSignal,  style=shape.triangleup,   location=location.belowbar,
     color=color.new(bullColor, 0), size=size.small, title="Bull Flip", text="ST↑", textcolor=color.white)
plotshape(showLabels and shortSignal, style=shape.triangledown, location=location.abovebar,
     color=color.new(bearColor, 0), size=size.small, title="Bear Flip", text="ST↓", textcolor=color.white)

// Regime blocked signal (gray)
plotshape(showLabels and bullFlip and not regimeOkLong,  style=shape.triangleup,   location=location.belowbar,
     color=color.new(color.gray, 60), size=size.tiny, title="Bull (Blocked)", text="✗")
plotshape(showLabels and bearFlip and not regimeOkShort, style=shape.triangledown, location=location.abovebar,
     color=color.new(color.gray, 60), size=size.tiny, title="Bear (Blocked)", text="✗")

// ═══════════════════════════════════════════════════════════════
// STATUS TABLE
// ═══════════════════════════════════════════════════════════════
var table stTable = table.new(position.bottom_right, 2, 7, border_width=1)

if barstate.islast
    dirText  = stDir < 0 ? "BULL" : "BEAR"
    dirColor = stDir < 0 ? color.new(bullColor, 20) : color.new(bearColor, 20)
    hdrBg    = color.new(#37474f, 10)
    regOk    = (isUptrend and isTrending) or (isDowntrend and isTrending)
    regColor = regOk ? color.new(bullColor, 30) : color.new(color.gray, 60)
    regText  = isTrending ? (isUptrend ? "UP TREND" : "DN TREND") : "RANGING"
    adxColor = adxVal > 25 ? color.new(bullColor, 40) : adxVal > 20 ? color.new(#ff9800, 40) : color.new(color.gray, 70)

    table.cell(stTable, 0, 0, "ST v1.2", bgcolor=hdrBg, text_color=color.white, text_size=size.small)
    table.cell(stTable, 1, 0, timeframe.period, bgcolor=hdrBg, text_color=color.white, text_size=size.small)
    table.cell(stTable, 0, 1, "Trend", text_size=size.small)
    table.cell(stTable, 1, 1, dirText, bgcolor=dirColor, text_color=color.white, text_size=size.small)
    table.cell(stTable, 0, 2, "Regime", text_size=size.small)
    table.cell(stTable, 1, 2, regText, bgcolor=regColor, text_color=color.white, text_size=size.small)
    table.cell(stTable, 0, 3, "ADX", text_size=size.small)
    table.cell(stTable, 1, 3, str.tostring(adxVal, "#.0"), bgcolor=adxColor, text_size=size.small)
    table.cell(stTable, 0, 4, "EMA200", text_size=size.small)
    table.cell(stTable, 1, 4, str.tostring(ema200, "#.0"), text_size=size.small)
    table.cell(stTable, 0, 5, "RSI", text_size=size.small)
    rsiColor = rsiVal > 70 ? color.new(bearColor, 30) : rsiVal < 30 ? color.new(bullColor, 30) : color.new(color.gray, 70)
    table.cell(stTable, 1, 5, str.tostring(rsiVal, "#.0"), bgcolor=rsiColor, text_size=size.small)
    table.cell(stTable, 0, 6, "Vol Ratio", text_size=size.small)
    vrColor = volRatio > 1.5 ? color.new(bullColor, 40) : volRatio > 1.0 ? color.new(#ff9800, 40) : color.new(color.gray, 70)
    table.cell(stTable, 1, 6, str.tostring(volRatio, "#.##") + "x", bgcolor=vrColor, text_size=size.small)
