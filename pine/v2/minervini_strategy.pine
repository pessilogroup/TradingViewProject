//@version=5
strategy(
    title = "Mark Minervini SEPA Strategy V2", 
    shorttitle = "Minervini Strat V2", 
    overlay = true, 
    initial_capital = 10000, 
    default_qty_type = strategy.percent_of_equity, 
    default_qty_value = 100, 
    commission_type = strategy.commission.percent, 
    commission_value = 0.1, // Phù hợp với phí giao dịch Crypto (VD: Binance)
    slippage = 2,           // Trượt giá
    process_orders_on_close = true // Sát thực tế khi backtest
)

// ================================================================================================= //
// INPUTS & SETTINGS
// ================================================================================================= //
grp_ma = "Moving Averages"
show_mas = input.bool(true, title="Hiển thị các đường MA", group=grp_ma)

grp_rs = "Relative Strength (RS) Settings"
rs_option = input.string("BTCUSD (Crypto)", title="Chọn Benchmark Market", options=["SPY (Thị trường Mỹ)", "VNINDEX (Thị trường VN)", "BTCUSD (Crypto)"], group=grp_rs)

grp_vcp = "VCP & Breakout Settings"
vol_breakout_mult = input.float(1.2, title="Volume Breakout Multiplier [MIS v1 khuyên dùng: 1.2x]", step=0.1, group=grp_vcp, tooltip="Minervini yêu cầu khối lượng lớn (Heavy Volume) khi vượt Pivot.")
vcp_lookback = input.int(10, title="Số nến tối đa từ VCP đến Breakout", minval=1, maxval=20, group=grp_vcp)

grp_risk = "Risk Management (MIS v1 Optimized)"
use_atr_stops = input.bool(true, title="Sử dụng SL/TP dựa trên ATR (MIS v1)", group=grp_risk)
atr_sl_mult = input.float(2.0, title="ATR Stop Loss Multiplier", group=grp_risk)
atr_tp_mult = input.float(3.0, title="ATR Take Profit Multiplier", group=grp_risk)
stop_loss_pct = input.float(8.0, title="Stop Loss Cố định (%)", minval=1.0, maxval=20.0, step=0.5, group=grp_risk)
take_profit_pct = input.float(20.0, title="Take Profit Cố định (%)", minval=1.0, step=1.0, group=grp_risk)
use_trailing_ma = input.bool(true, title="Bán khi thủng SMA 50 (Trailing Stop)", group=grp_risk)

grp_webhook = "Webhook Settings"
webhook_secret = input.string("change_me_in_dotenv", title="Webhook Secret", group=grp_webhook)

grp_ui = "UI Settings"
show_table = input.bool(true, title="Hiển thị bảng trạng thái (Table)", group=grp_ui)

// Determine Benchmark Ticker
string benchmark_ticker = "BTCUSD" 
if rs_option == "SPY (Thị trường Mỹ)"
    benchmark_ticker := "SPY"
else if rs_option == "VNINDEX (Thị trường VN)"
    benchmark_ticker := "VNINDEX"
else if rs_option == "BTCUSD (Crypto)"
    benchmark_ticker := "BTCUSD"

// ================================================================================================= //
// DATA CALCULATIONS
// ================================================================================================= //

// 1. Moving Averages
sma50 = ta.sma(close, 50)
sma150 = ta.sma(close, 150)
sma200 = ta.sma(close, 200)

// 2. 52-Week High & Low (approximated as 250 trading days)
high52 = ta.highest(high, 250)
low52 = ta.lowest(low, 250)

// 3. Relative Strength (Outperformance over the last 125 days / 6 months)
bench_close = request.security(benchmark_ticker, timeframe.period, close)
stock_perf = (close - close[125]) / close[125]
bench_perf = (bench_close - bench_close[125]) / bench_close[125]

// ================================================================================================= //
// TREND TEMPLATE CONDITIONS (8 Rules)
// ================================================================================================= //

cond1 = close > sma150 and close > sma200
cond2 = sma150 > sma200
cond3 = sma200 > sma200[20]
cond4 = sma50 > sma150 and sma50 > sma200
cond5 = close > sma50
cond6 = close >= (low52 * 1.30)
cond7 = close >= (high52 * 0.75)
cond8 = stock_perf > bench_perf

trend_template_met = cond1 and cond2 and cond3 and cond4 and cond5 and cond6 and cond7 and cond8

// ================================================================================================= //
// VCP & BREAKOUT DETECTOR
// ================================================================================================= //
vol_sma = ta.sma(volume, 50)

// Điều kiện VCP: Thanh khoản cạn kiệt (<50% trung bình) & Biên độ hẹp
vol_dry_up = volume < (vol_sma * 0.5)
atr = ta.atr(14)
tight_range = (high - low) < (atr * 0.5)

vcp_signal = vol_dry_up and tight_range

// Lưu lại Pivot Point
var float pivot_price = na
var int pivot_bar = na

if vcp_signal
    pivot_price := high
    pivot_bar := bar_index

// Tín hiệu Breakout
bars_since_pivot = bar_index - pivot_bar
is_breakout = ta.crossover(close, pivot_price) and bars_since_pivot <= vcp_lookback and bars_since_pivot > 0
vol_breakout = volume > (vol_sma * vol_breakout_mult)

buy_signal = trend_template_met and is_breakout and vol_breakout

// ================================================================================================= //
// STRATEGY EXECUTION (RISK MANAGEMENT & WEBHOOK)
// ================================================================================================= //

// Tính toán SL / TP động (Chỉ dùng cho Visual Backtest trên TradingView)
var float current_sl = na
var float current_tp = na

if buy_signal and strategy.position_size == 0
    if use_atr_stops
        current_sl := close - (atr * atr_sl_mult)
        current_tp := close + (atr * atr_tp_mult)
    else
        current_sl := close * (1 - (stop_loss_pct / 100))
        current_tp := close * (1 + (take_profit_pct / 100))
        
    // 🧠 GỬI TÍN HIỆU CHO AI BRAIN (ACTION = "alert")
    alert_msg = '{"secret": "' + webhook_secret + '", "action": "alert", "symbol": "' + syminfo.ticker + '", "price": ' + str.tostring(close) + ', "interval": "' + timeframe.period + '"}'
    
    // Gửi webhook dưới dạng Alert thay vì Entry cứng
    alert(alert_msg, alert.freq_once_per_bar_close)
    
    // Strategy entry chỉ dùng để backtest trên web
    strategy.entry("SEPA Long", strategy.long)

// Quản lý lệnh đang mở (Chỉ dùng cho Visual Backtest)
if strategy.position_size > 0
    // Nếu SL/TP không hợp lệ (VD: đổi logic giữa chừng), tính lại tạm
    stop_price = na(current_sl) ? strategy.position_avg_price * (1 - (stop_loss_pct / 100)) : current_sl
    limit_price = na(current_tp) ? strategy.position_avg_price * (1 + (take_profit_pct / 100)) : current_tp
    
    // Cắt lỗ thủng MA50 (Trailing Stop)
    if use_trailing_ma and close < sma50
        alert_msg_sell = '{"secret": "' + webhook_secret + '", "action": "sell", "symbol": "' + syminfo.ticker + '", "price": ' + str.tostring(close) + ', "interval": "' + timeframe.period + '"}'
        alert(alert_msg_sell, alert.freq_once_per_bar_close)
        strategy.close("SEPA Long", comment="Thủng MA50")
    else
        strategy.exit("Take Profit / Stop Loss", "SEPA Long", stop=stop_price, limit=limit_price)

// ================================================================================================= //
// VISUALS & PLOTS
// ================================================================================================= //

plot(show_mas ? sma50 : na, color=color.blue, title="SMA 50", linewidth=1)
plot(show_mas ? sma150 : na, color=color.orange, title="SMA 150", linewidth=1)
plot(show_mas ? sma200 : na, color=color.red, title="SMA 200", linewidth=2)

// Vẽ Pivot Point Line
plot(bars_since_pivot <= vcp_lookback ? pivot_price : na, color=color.new(color.fuchsia, 30), style=plot.style_linebr, linewidth=2, title="VCP Pivot Line")

barcolor(trend_template_met ? color.new(color.green, 0) : na, title="Trend Template Color")

plotshape(series=vcp_signal, title="VCP Setup", style=shape.triangleup, location=location.belowbar, color=color.new(color.gray, 0), size=size.small, text="VCP", textcolor=color.gray)
plotshape(series=buy_signal, title="Breakout Buy", style=shape.labelup, location=location.belowbar, color=color.new(color.green, 0), size=size.normal, text="BUY", textcolor=color.white)

// ================================================================================================= //
// STATUS TABLE
// ================================================================================================= //
var table statusTable = table.new(position.bottom_right, 2, 9, border_width=1)

if show_table and barstate.islast
    table.cell(statusTable, 0, 0, "Tiêu chuẩn Trend Template", bgcolor=color.new(color.gray, 30), text_color=color.white)
    table.cell(statusTable, 1, 0, "Trạng thái", bgcolor=color.new(color.gray, 30), text_color=color.white)
    
    table.cell(statusTable, 0, 1, "1. Giá > SMA 150 & 200")
    table.cell(statusTable, 1, 1, cond1 ? "ĐẠT" : "CHƯA", bgcolor=cond1 ? color.new(color.green, 70) : color.new(color.red, 70))
    table.cell(statusTable, 0, 2, "2. SMA 150 > SMA 200")
    table.cell(statusTable, 1, 2, cond2 ? "ĐẠT" : "CHƯA", bgcolor=cond2 ? color.new(color.green, 70) : color.new(color.red, 70))
    table.cell(statusTable, 0, 3, "3. SMA 200 dốc lên")
    table.cell(statusTable, 1, 3, cond3 ? "ĐẠT" : "CHƯA", bgcolor=cond3 ? color.new(color.green, 70) : color.new(color.red, 70))
    table.cell(statusTable, 0, 4, "4. SMA 50 > SMA 150 & 200")
    table.cell(statusTable, 1, 4, cond4 ? "ĐẠT" : "CHƯA", bgcolor=cond4 ? color.new(color.green, 70) : color.new(color.red, 70))
    table.cell(statusTable, 0, 5, "5. Giá > SMA 50")
    table.cell(statusTable, 1, 5, cond5 ? "ĐẠT" : "CHƯA", bgcolor=cond5 ? color.new(color.green, 70) : color.new(color.red, 70))
    table.cell(statusTable, 0, 6, "6. Giá cách đáy 52W > 30%")
    table.cell(statusTable, 1, 6, cond6 ? "ĐẠT" : "CHƯA", bgcolor=cond6 ? color.new(color.green, 70) : color.new(color.red, 70))
    table.cell(statusTable, 0, 7, "7. Giá cách đỉnh 52W < 25%")
    table.cell(statusTable, 1, 7, cond7 ? "ĐẠT" : "CHƯA", bgcolor=cond7 ? color.new(color.green, 70) : color.new(color.red, 70))
    table.cell(statusTable, 0, 8, "8. RS > Benchmark")
    table.cell(statusTable, 1, 8, cond8 ? "ĐẠT" : "CHƯA", bgcolor=cond8 ? color.new(color.green, 70) : color.new(color.red, 70))
