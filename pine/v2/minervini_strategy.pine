// ================================================================================================= //
// Mark Minervini SEPA Strategy V2 (Merged MIS v1.6 & MTT v1.005-b)
// ================================================================================================= //
// Hợp nhất hai dòng chiến lược thành một mã nguồn duy nhất:
// 1. Chế độ Daily Trend Follower (MTT v1.005-b): Bám xu hướng dài hạn bằng EMA 20/50/100, Long Only.
// 2. Chế độ 1H SEPA / Momentum (MIS v1.6): Giao dịch theo VCP breakout trên khung 1H, kết hợp 8 tiêu chí Trend Template.
// ================================================================================================= //

//@version=5
strategy(
     title                   = "Mark Minervini SEPA Strategy V2",
     shorttitle              = "Minervini Strat V2",
     overlay                 = true,
     initial_capital         = 100000,
     default_qty_type        = strategy.percent_of_equity,
     default_qty_value       = 10,
     commission_type         = strategy.commission.percent,
     commission_value        = 0.075,
     slippage                = 2,
     pyramiding              = 0,
     process_orders_on_close = true,
     calc_on_every_tick      = false
 )

// ================================================================================================= //
// INPUTS & SETTINGS
// ================================================================================================= //
grp_mode = "Strategy Mode"
strat_mode = input.string("Daily Trend Follower (MTT v1.005-b)", title="Strategy Mode", 
     options=["Daily Trend Follower (MTT v1.005-b)", "1H SEPA / Momentum (MIS v1.6)"], group=grp_mode,
     tooltip="Chọn chế độ vận hành: Daily Trend Follower (Daily EMA 20/50/100) hoặc 1H SEPA/Momentum (1H VCP breakout).")

grp_dir   = "Direction (MIS Mode only)"
allow_long  = input.bool(true,  "Allow Long entries",  group=grp_dir)
allow_short = input.bool(false, "Allow Short entries", group=grp_dir)

grp_ma = "Moving Averages Settings"
ma_type  = input.string("EMA", "MA Type (MTT Mode)", options=["SMA","EMA","WMA","HMA"], group=grp_ma)
fast_len = input.int(20,  "Fast MA Period",   minval=5,  group=grp_ma)
med_len  = input.int(50,  "Medium MA Period", minval=10, group=grp_ma)
slow_len_mtt = input.int(100, "Slow MA (MTT Mode)", minval=20, group=grp_ma)
slow_len_mis = input.int(200, "Slow MA (MIS Mode)", minval=20, group=grp_ma)

grp_rs = "Relative Strength (RS) Settings"
rs_option = input.string("BTCUSD (Crypto)", title="Chọn Benchmark Market", 
     options=["SPY (Thị trường Mỹ)", "VNINDEX (Thị trường VN)", "BTCUSD (Crypto)"], group=grp_rs)
disable_rs = input.bool(false, "Disable RS criterion", group=grp_rs,
     tooltip="Bỏ qua tiêu chí Relative Strength (ví dụ khi giao dịch trực tiếp benchmark).")

grp_vcp = "VCP & Breakout Settings (MIS Mode only)"
vcp_lookback = input.int(20, "VCP lookback (bars)", minval=5, maxval=50, group=grp_vcp,
     tooltip="Số nến để quét tìm VCP setup (volume dry-up + tight range).")
vcp_dry_pct  = input.float(0.6, "Volume dry-up threshold (x MA)", step=0.05, group=grp_vcp)
vcp_tight_atr = input.float(0.7, "Range tightness (x ATR)", step=0.1, group=grp_vcp)
breakout_window = input.int(15, "Breakout window size (bars)", minval=3, maxval=50, group=grp_vcp)
vol_mult   = input.float(1.5, "Breakout Volume Multiplier", step=0.1, group=grp_vcp)

grp_risk = "Risk Management Settings"
profile  = input.string("Futures", "MTT Profile Sizing", options=["Spot","Margin","Futures"], group=grp_risk,
     tooltip="Spot (10%), Margin (20%), Futures (10%)")
risk_pct      = input.float(1.0,  "Risk per trade (% equity - MIS)", minval=0.1, maxval=5.0, step=0.1, group=grp_risk)
atr_sl_mul    = input.float(2.0,  "ATR Stop Loss Multiplier",    step=0.1, group=grp_risk)
atr_tp_mul    = input.float(8.0,  "ATR Take Profit Multiplier",  step=0.5, group=grp_risk, tooltip="Chỉ áp dụng trong MIS mode.")
hard_sl_pct   = input.float(8.0,  "Hard Stop-Loss Cap (%)",      minval=2.0, maxval=20.0, step=0.5, group=grp_risk)
max_pos_pct   = input.float(95.0, "Max position notional (% equity)", minval=10.0, maxval=100.0, step=5.0, group=grp_risk)
use_atr_trail = input.bool(true,  "ATR trailing stop (Chandelier)", group=grp_risk)
trail_atr_mul = input.float(3.0,  "Trail ATR Multiplier",        step=0.5, group=grp_risk)
use_ma_trail  = input.bool(false, "Exit on close < SMA50",       group=grp_risk)
cooldown_bars = input.int(3,      "Cooldown bars after exit (MIS)", minval=0, maxval=50, group=grp_risk)

grp_webhook = "Webhook Settings"
webhook_secret = input.string("change_me_in_dotenv", title="Webhook Secret", group=grp_webhook)

grp_ui = "UI Settings"
show_table = input.bool(true, "Hiển thị bảng trạng thái (Table)", group=grp_ui)
show_mas = input.bool(true, "Hiển thị các đường MA", group=grp_ui)

// ================================================================================================= //
// DATA CALCULATIONS
// ================================================================================================= //
// 1. Benchmark Selection
string benchmark_ticker = "BTCUSD" 
if rs_option == "SPY (Thị trường Mỹ)"
    benchmark_ticker := "SPY"
else if rs_option == "VNINDEX (Thị trường VN)"
    benchmark_ticker := "VNINDEX"
else if rs_option == "BTCUSD (Crypto)"
    benchmark_ticker := "BTCUSD"

// 2. Moving Averages Helper
ma_helper(mtype, len, src) =>
    switch mtype
        "SMA"  => ta.sma(src, len)
        "EMA"  => ta.ema(src, len)
        "WMA"  => ta.wma(src, len)
        "HMA"  => ta.hma(src, len)
        =>        ta.sma(src, len)

// Cấu hình MA linh hoạt theo Mode
ma_slow_len = (strat_mode == "Daily Trend Follower (MTT v1.005-b)") ? slow_len_mtt : slow_len_mis

// Tính toán các đường MA local trên khung thời gian hiện tại (Local Timeframe)
local_mf = ma_helper(ma_type, fast_len, close)
local_mm = ma_helper(ma_type, med_len, close)
local_ms = ma_helper(ma_type, ma_slow_len, close)

// Tính toán các đường MA Daily (EMA 20/50/100) tránh lookahead bias bằng cách dùng [1] và lookahead_off
daily_mf = request.security(syminfo.tickerid, "D", ta.ema(close, 20)[1], barmerge.gaps_off, barmerge.lookahead_off)
daily_mm = request.security(syminfo.tickerid, "D", ta.ema(close, 50)[1], barmerge.gaps_off, barmerge.lookahead_off)
daily_ms = request.security(syminfo.tickerid, "D", ta.ema(close, 100)[1], barmerge.gaps_off, barmerge.lookahead_off)

// Gán biến kết quả dựa theo Strategy Mode
is_mtt = (strat_mode == "Daily Trend Follower (MTT v1.005-b)")
mf = is_mtt ? daily_mf : local_mf
mm = is_mtt ? daily_mm : local_mm
ms = is_mtt ? daily_ms : local_ms

// 3. Technical indicators for MIS mode
sma50  = ta.sma(close, 50)
sma150 = ta.sma(close, 150)
sma200 = ta.sma(close, 200)
rsi    = ta.rsi(close, 14)
atr    = ta.atr(14)
vol_ma = ta.sma(volume, 50)
heavy_vol = volume > (vol_ma * vol_mult)

// 52-Week High & Low
high52 = ta.highest(high, 250)
low52  = ta.lowest(low,   250)

// Relative Strength Calculation
bench = request.security(benchmark_ticker, timeframe.period, close, ignore_invalid_symbol=true)
stk_perf  = (close - close[125]) / close[125]
bench_perf = (bench - bench[125]) / bench[125]

// ================================================================================================= //
// STRATEGY LOGIC
// ================================================================================================= //
var float current_sl = na
var float current_tp = na
var int last_exit_bar = na

// ─── A. DAILY TREND FOLLOWER (MTT MODE) ─────────────────────────────────────────────────────────
bull = mf > mm and mm > ms
bull_start = (strat_mode == "Daily Trend Follower (MTT v1.005-b)") and bull and not bull[1]
bull_end   = (strat_mode == "Daily Trend Follower (MTT v1.005-b)") and not bull and bull[1]

// Tín hiệu Breakout Long từ Short kết thúc
bear = mf < mm and mm < ms
bear_end = not bear and bear[1]
breakout_long = (strat_mode == "Daily Trend Follower (MTT v1.005-b)") and bear_end

// Sizing cho MTT Mode
spot_pct    = 10.0
margin_pct  = 20.0
futures_pct = 10.0
qty_pct = profile == "Spot" ? spot_pct : (profile == "Margin" ? margin_pct : futures_pct)
qty_mtt = (strategy.equity * qty_pct / 100.0) / close

// ─── B. 1H SEPA / MOMENTUM (MIS MODE) ──────────────────────────────────────────────────────────
// Trend Template Gate (8 Criteria)
tt1 = close > sma150 and close > sma200
tt2 = sma150 > sma200
tt3 = sma200 > sma200[20]
tt4 = sma50 > sma150 and sma50 > sma200
tt5 = close > sma50
tt6 = close >= low52 * 1.30
tt7 = close >= high52 * 0.75
tt8 = disable_rs ? true : (stk_perf > bench_perf)
trend_template_ok = tt1 and tt2 and tt3 and tt4 and tt5 and tt6 and tt7 and tt8

// VCP Pivot Detection
vol_dry = volume < (vol_ma * vcp_dry_pct)
tight   = (high - low) < (atr * vcp_tight_atr)
vcp_bar = vol_dry and tight

var float pivot_price = na
var int   pivot_bar   = na
if (strat_mode == "1H SEPA / Momentum (MIS v1.6)") and vcp_bar
    pivot_price := high
    pivot_bar   := bar_index

bars_since_pivot = na(pivot_bar) ? 9999 : (bar_index - pivot_bar)
vcp_recent_active = bars_since_pivot > 0 and bars_since_pivot <= breakout_window
is_breakout = vcp_recent_active and not na(pivot_price) and ta.crossover(close, pivot_price)

// Entry filters
trend_up   = mf > mm and mm > ms
rsi_ok     = rsi > 50
long_filter  = trend_up and rsi_ok and is_breakout and heavy_vol and trend_template_ok

in_cooldown = not na(last_exit_bar) and (bar_index - last_exit_bar) < cooldown_bars
long_entry_mis = (strat_mode == "1H SEPA / Momentum (MIS v1.6)") and allow_long and long_filter and strategy.position_size == 0 and not in_cooldown

// Sizing cho MIS Mode (Risk-based)
sl_dist_atr  = na(atr) ? 0.0 : atr * atr_sl_mul
sl_dist_pct  = close * hard_sl_pct / 100
sl_distance  = math.max(math.min(sl_dist_atr > 0 ? sl_dist_atr : sl_dist_pct, sl_dist_pct), close * 0.005)
equity_safe  = math.max(strategy.equity, 100)
risk_capital = equity_safe * risk_pct / 100
qty_by_risk  = risk_capital / sl_distance
qty_by_cap   = (equity_safe * max_pos_pct / 100) / close
qty_mis      = math.min(qty_by_risk, qty_by_cap)

// ================================================================================================= //
// STRATEGY EXECUTION & ALERTS
// ================================================================================================= //
var float entry_atr = na
var float trail_high = na

// ─── Entry Executes ───
if (strat_mode == "Daily Trend Follower (MTT v1.005-b)") and bull_start
    qty_final = math.max(qty_mtt, 0.0001)
    strategy.entry("MTT Long", strategy.long, qty=qty_final, comment="Bull Start")
    alert_msg = '{"secret": "' + webhook_secret + '", "action": "alert", "symbol": "' + syminfo.ticker + '", "price": ' + str.tostring(close) + ', "interval": "' + timeframe.period + '", "mode": "MTT"}'
    alert(alert_msg, alert.freq_once_per_bar_close)

if (strat_mode == "1H SEPA / Momentum (MIS v1.6)") and long_entry_mis
    qty_final = math.max(qty_mis, 0.0001)
    strategy.entry("MIS Long", strategy.long, qty=qty_final, comment="MIS Breakout")
    entry_atr := atr
    trail_high := high
    current_sl := close - (atr * atr_sl_mul)
    current_tp := close + (atr * atr_tp_mul)
    alert_msg = '{"secret": "' + webhook_secret + '", "action": "alert", "symbol": "' + syminfo.ticker + '", "price": ' + str.tostring(close) + ', "interval": "' + timeframe.period + '", "mode": "MIS"}'
    alert(alert_msg, alert.freq_once_per_bar_close)

// ─── Exit Executes ───
if (strat_mode == "Daily Trend Follower (MTT v1.005-b)") and bull_end
    strategy.close("MTT Long", comment="Bull End")
    alert_msg_sell = '{"secret": "' + webhook_secret + '", "action": "sell", "symbol": "' + syminfo.ticker + '", "price": ' + str.tostring(close) + ', "interval": "' + timeframe.period + '", "mode": "MTT"}'
    alert(alert_msg_sell, alert.freq_once_per_bar_close)

if (strat_mode == "1H SEPA / Momentum (MIS v1.6)") and strategy.position_size > 0
    avg = strategy.position_avg_price
    trail_high := math.max(trail_high, high)
    sl_hard  = math.max(avg - entry_atr * atr_sl_mul, avg * (1 - hard_sl_pct / 100))
    sl_trail = trail_high - atr * trail_atr_mul
    sl  = use_atr_trail ? math.max(sl_hard, sl_trail) : sl_hard
    tp  = avg + entry_atr * atr_tp_mul
    
    if use_ma_trail and close < sma50
        strategy.close("MIS Long", comment="MA50 trail")
        alert_msg_sell = '{"secret": "' + webhook_secret + '", "action": "sell", "symbol": "' + syminfo.ticker + '", "price": ' + str.tostring(close) + ', "interval": "' + timeframe.period + '", "mode": "MIS"}'
        alert(alert_msg_sell, alert.freq_once_per_bar_close)
    else
        strategy.exit("MIS Exit", "MIS Long", stop=sl, limit=tp)

// Reset / Cooldown tracking
if strategy.position_size == 0 and strategy.position_size[1] != 0
    last_exit_bar := bar_index
    trail_high := na
    entry_atr := na

// ================================================================================================= //
// VISUALS & PLOTS
// ================================================================================================= //
p_f = plot(show_mas ? mf : na, color=color.blue,   title="Fast MA")
p_m = plot(show_mas ? mm : na, color=color.orange, title="Medium MA")
p_s = plot(show_mas ? ms : na, color=color.red,    title="Slow MA", linewidth=2)

// Tô nền vùng Bullish
fill(p_f, p_s, color=(strat_mode == "Daily Trend Follower (MTT v1.005-b)" and bull) ? color.new(color.green, 85) : na, title="Bull Stack Zone")

// Vẽ đường Pivot Line (MIS Mode)
plot((strat_mode == "1H SEPA / Momentum (MIS v1.6)" and vcp_recent_active) ? pivot_price : na, 
     color=color.new(color.fuchsia, 30), style=plot.style_linebr, linewidth=2, title="VCP Pivot Line")

// Vẽ các Marker kích hoạt
plotshape(bull_start, title="MTT Long Start", style=shape.triangleup, location=location.belowbar, color=color.new(color.green,0),  size=size.small, text="MTT LONG")
plotshape(bull_end,   title="MTT Long End",   style=shape.xcross,     location=location.abovebar, color=color.new(color.red,30), size=size.small)

plotshape((strat_mode == "1H SEPA / Momentum (MIS v1.6)" and long_entry_mis),  title="MIS Long Entry",  shape.labelup,   location=location.belowbar, color=color.new(color.green, 0), size=size.normal, text="BUY", textcolor=color.white)
plotshape(breakout_long, title="Breakout Long (BO)", style=shape.diamond, location=location.belowbar, color=color.new(color.aqua,0), size=size.small, text="BO")

// Cảnh báo Breakout
alertcondition(breakout_long, title="MTT Breakout Long", message="Bear stack ended — potential long break-out")

// ================================================================================================= //
// STATUS TABLE (UI)
// ================================================================================================= //
var table statusTable = table.new(position.bottom_right, 2, 10, border_width=1)
bg_ok(b) => b ? color.new(color.green, 70) : color.new(color.red, 70)
mark(b)  => b ? "ĐẠT" : "CHƯA"

if show_table and barstate.islast
    if strat_mode == "Daily Trend Follower (MTT v1.005-b)"
        table.cell(statusTable, 0, 0, "Chỉ số MTT Daily", bgcolor=color.new(color.blue, 30), text_color=color.white)
        table.cell(statusTable, 1, 0, "Trạng thái", bgcolor=color.new(color.blue, 30), text_color=color.white)
        
        table.cell(statusTable, 0, 1, "1. Fast MA > Med MA")
        table.cell(statusTable, 1, 1, mf > mm ? "ĐẠT" : "CHƯA", bgcolor=bg_ok(mf > mm))
        table.cell(statusTable, 0, 2, "2. Med MA > Slow MA")
        table.cell(statusTable, 1, 2, mm > ms ? "ĐẠT" : "CHƯA", bgcolor=bg_ok(mm > ms))
        table.cell(statusTable, 0, 3, "3. Bull Stack (Long)")
        table.cell(statusTable, 1, 3, bull ? "ACTIVE" : "OFF", bgcolor=bull ? color.new(color.green, 70) : color.new(color.gray, 70))
        table.cell(statusTable, 0, 4, "4. Bear Stack (Short)")
        table.cell(statusTable, 1, 4, bear ? "ACTIVE" : "OFF", bgcolor=bear ? color.new(color.red, 70) : color.new(color.gray, 70))
    else
        table.cell(statusTable, 0, 0, "Tiêu chuẩn Trend Template (MIS)", bgcolor=color.new(color.gray, 30), text_color=color.white)
        table.cell(statusTable, 1, 0, "Trạng thái", bgcolor=color.new(color.gray, 30), text_color=color.white)
        
        table.cell(statusTable, 0, 1, "1. Giá > SMA 150 & 200")
        table.cell(statusTable, 1, 1, mark(tt1), bgcolor=bg_ok(tt1))
        table.cell(statusTable, 0, 2, "2. SMA 150 > SMA 200")
        table.cell(statusTable, 1, 2, mark(tt2), bgcolor=bg_ok(tt2))
        table.cell(statusTable, 0, 3, "3. SMA 200 dốc lên (20 nến)")
        table.cell(statusTable, 1, 3, mark(tt3), bgcolor=bg_ok(tt3))
        table.cell(statusTable, 0, 4, "4. SMA 50 > SMA 150 & 200")
        table.cell(statusTable, 1, 4, mark(tt4), bgcolor=bg_ok(tt4))
        table.cell(statusTable, 0, 5, "5. Giá > SMA 50")
        table.cell(statusTable, 1, 5, mark(tt5), bgcolor=bg_ok(tt5))
        table.cell(statusTable, 0, 6, "6. Giá cách đáy 52W >= 30%")
        table.cell(statusTable, 1, 6, mark(tt6), bgcolor=bg_ok(tt6))
        table.cell(statusTable, 0, 7, "7. Giá cách đỉnh 52W <= 25%")
        table.cell(statusTable, 1, 7, mark(tt7), bgcolor=bg_ok(tt7))
        table.cell(statusTable, 0, 8, "8. RS > Benchmark")
        table.cell(statusTable, 1, 8, mark(tt8), bgcolor=bg_ok(tt8))
        table.cell(statusTable, 0, 9, "9. RSI > 50")
        table.cell(statusTable, 1, 9, mark(rsi_ok), bgcolor=bg_ok(rsi_ok))
