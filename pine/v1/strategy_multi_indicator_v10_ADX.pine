//@version=5
// =============================================================================
//  Multi-Indicator Strategy V1 + ADX/Slope regime filter
//  Pragmatic upgrade: keep v10 entry/exit unchanged, add 2 toggleable filters:
//    - ADX(14) >= adx_min  → only trade when trend strength confirmed
//    - EMA200 slope > 0 (long) / < 0 (short) over slope_lookback bars
//  Targets the v10 walk-forward weakness: −28.98 USDT in Q1+Q2 2025 chop.
// =============================================================================

strategy(
     title       = "Multi-Indicator Strategy V1 + ADX/Slope",
     shorttitle  = "MIS v10-ADX",
     overlay     = true,
     initial_capital    = 1000,
     default_qty_type   = strategy.percent_of_equity,
     default_qty_value  = 2,
     commission_type    = strategy.commission.percent,
     commission_value   = 0.05,
     slippage           = 2,
     pyramiding         = 0,
     process_orders_on_close = true
 )

// ─── INPUTS ───────────────────────────────────────────────────────────────────
allow_long  = input.bool(true,  "Allow Long")
allow_short = input.bool(true,  "Allow Short")

ema_fast = input.int(20,  "EMA Fast")
ema_mid  = input.int(50,  "EMA Mid")
ema_slow = input.int(200, "EMA Slow")
rsi_len  = input.int(14,  "RSI Length")
rsi_ob   = input.int(70,  "RSI OB")
rsi_os   = input.int(30,  "RSI OS")
atr_len  = input.int(14,  "ATR Length")
atr_sl_mul = input.float(2.0, "ATR SL Mul", step=0.1)
atr_tp_mul = input.float(3.0, "ATR TP Mul", step=0.1)
vol_ma_len = input.int(20, "Volume MA Length")
vol_mult   = input.float(1.5, "Volume Multiplier", step=0.1)

// Regime filters (the 2 additions)
use_adx    = input.bool(true, "Use ADX filter", group="Regime")
adx_len    = input.int(14, "ADX Length", minval=1, group="Regime")
adx_smooth = input.int(14, "ADX Smoothing", minval=1, group="Regime")
adx_min    = input.float(25.0, "ADX min", step=1.0, group="Regime")

use_slope  = input.bool(true, "Use EMA200 slope filter", group="Regime")
slope_lookback = input.int(20, "Slope lookback (bars)", minval=5, maxval=100, group="Regime")
slope_min_pct  = input.float(0.0, "Slope min % over lookback", step=0.1, group="Regime",
     tooltip="Long requires slope > this; short requires slope < -this.")

// ─── INDICATORS ───────────────────────────────────────────────────────────────
ema20  = ta.ema(close, ema_fast)
ema50  = ta.ema(close, ema_mid)
ema200 = ta.ema(close, ema_slow)
rsi    = ta.rsi(close, rsi_len)
[macd_line, signal_line, _] = ta.macd(close, 12, 26, 9)
mcu = ta.crossover(macd_line, signal_line)
mcd = ta.crossunder(macd_line, signal_line)
atr    = ta.atr(atr_len)
vol_ma = ta.sma(volume, vol_ma_len)
heavy_vol = volume > vol_ma * vol_mult

[diplus, diminus, adx] = ta.dmi(adx_len, adx_smooth)
slope_pct = (ema200 - ema200[slope_lookback]) / ema200[slope_lookback] * 100

trend_up   = ema20 > ema50 and ema50 > ema200
trend_down = ema20 < ema50 and ema50 < ema200
rsi_long   = rsi > 50 and rsi < rsi_ob
rsi_short  = rsi < 50 and rsi > rsi_os

// Regime gates
adx_ok       = not use_adx or adx >= adx_min
slope_ok_long  = not use_slope or slope_pct >  slope_min_pct
slope_ok_short = not use_slope or slope_pct < -slope_min_pct

// ─── ENTRY ────────────────────────────────────────────────────────────────────
long_filter  = trend_up   and rsi_long  and mcu and heavy_vol and adx_ok and slope_ok_long
short_filter = trend_down and rsi_short and mcd and heavy_vol and adx_ok and slope_ok_short

long_entry  = allow_long  and long_filter  and strategy.position_size == 0
short_entry = allow_short and short_filter and strategy.position_size == 0

// ─── EXITS (v10 unchanged) ────────────────────────────────────────────────────
var float sp = na
var float tp = na
if long_entry
    sp := close - atr * atr_sl_mul
    tp := close + atr * atr_tp_mul
if short_entry
    sp := close + atr * atr_sl_mul
    tp := close - atr * atr_tp_mul

if long_entry
    strategy.entry("Long", strategy.long)
if short_entry
    strategy.entry("Short", strategy.short)

if strategy.position_size > 0
    strategy.exit("Long Exit", "Long", stop=sp, limit=tp)
if strategy.position_size < 0
    strategy.exit("Short Exit", "Short", stop=sp, limit=tp)

// ─── VISUALS ──────────────────────────────────────────────────────────────────
plot(ema20,  "EMA 20",  color=color.new(color.blue,   0))
plot(ema50,  "EMA 50",  color=color.new(color.orange, 0))
plot(ema200, "EMA 200", color=color.new(color.red,    0), linewidth=2)
plotshape(long_entry,  "Long",  shape.triangleup,   location.belowbar, color.new(color.green, 0), size=size.small)
plotshape(short_entry, "Short", shape.triangledown, location.abovebar, color.new(color.red,   0), size=size.small)
bgcolor(adx_ok ? color.new(color.green, 95) : color.new(color.red, 95), title="ADX OK")
