//@version=5
strategy(
     title       = "Multi-Indicator Strategy (EMA + RSI + MACD + Volume + ATR)",
     shorttitle  = "MIS v1",
     overlay     = true,
     default_qty_type  = strategy.percent_of_equity,
     default_qty_value = 2,
     commission_type   = strategy.commission.percent,
     commission_value  = 0.05,
     slippage          = 2
 )

// ─── INPUTS ───────────────────────────────────────────────────────────────────
ema_fast   = input.int(20,  "EMA Fast",   minval=1)
ema_mid    = input.int(50,  "EMA Mid",    minval=1)
ema_slow   = input.int(200, "EMA Slow",   minval=1)

rsi_len    = input.int(14,  "RSI Length", minval=1)
rsi_ob     = input.int(70,  "RSI Overbought")
rsi_os     = input.int(30,  "RSI Oversold")

macd_fast  = input.int(12,  "MACD Fast")
macd_slow  = input.int(26,  "MACD Slow")
macd_sig   = input.int(9,   "MACD Signal")

atr_len    = input.int(14,  "ATR Length")
atr_sl_mul = input.float(2.0, "ATR Stop Loss Multiplier",  step=0.1)
atr_tp_mul = input.float(3.0, "ATR Take Profit Multiplier", step=0.1)

vol_ma_len = input.int(20,  "Volume MA Length")
vol_mult   = input.float(1.5, "Volume Multiplier", step=0.1)

use_trail  = input.bool(false, "Use Trailing Stop")

// ─── INDICATORS ──────────────────────────────────────────────────────────────
ema20  = ta.ema(close, ema_fast)
ema50  = ta.ema(close, ema_mid)
ema200 = ta.ema(close, ema_slow)

rsi    = ta.rsi(close, rsi_len)

[macd_line, signal_line, _] = ta.macd(close, macd_fast, macd_slow, macd_sig)
macd_cross_up   = ta.crossover(macd_line, signal_line)
macd_cross_down = ta.crossunder(macd_line, signal_line)

atr    = ta.atr(atr_len)
vol_ma = ta.sma(volume, vol_ma_len)
high_vol = volume > vol_ma * vol_mult

// ─── CONDITIONS ──────────────────────────────────────────────────────────────
trend_up   = ema20 > ema50 and ema50 > ema200
trend_down = ema20 < ema50 and ema50 < ema200

rsi_long  = rsi > 50 and rsi < rsi_ob
rsi_short = rsi < 50 and rsi > rsi_os

long_entry  = trend_up   and rsi_long  and macd_cross_up   and high_vol
short_entry = trend_down and rsi_short and macd_cross_down and high_vol

// ─── STOP LOSS & TAKE PROFIT ─────────────────────────────────────────────────
var float sl_price = na
var float tp_price = na

if long_entry and strategy.position_size == 0
    sl_price := close - atr * atr_sl_mul
    tp_price := close + atr * atr_tp_mul

if short_entry and strategy.position_size == 0
    sl_price := close + atr * atr_sl_mul
    tp_price := close - atr * atr_tp_mul

// ─── ORDERS ───────────────────────────────────────────────────────────────────
if long_entry
    strategy.entry("Long", strategy.long,
         alert_message = '{"action":"buy","symbol":"' + syminfo.ticker + '","price":"' + str.tostring(close) + '","time":"' + str.tostring(timenow) + '"}')

if short_entry
    strategy.entry("Short", strategy.short,
         alert_message = '{"action":"sell","symbol":"' + syminfo.ticker + '","price":"' + str.tostring(close) + '","time":"' + str.tostring(timenow) + '"}')

if strategy.position_size > 0
    if use_trail
        strategy.exit("Long Exit", "Long", trail_points = atr * atr_sl_mul / syminfo.mintick, trail_offset = atr * atr_sl_mul / syminfo.mintick)
    else
        strategy.exit("Long Exit", "Long", stop = sl_price, limit = tp_price)

if strategy.position_size < 0
    if use_trail
        strategy.exit("Short Exit", "Short", trail_points = atr * atr_sl_mul / syminfo.mintick, trail_offset = atr * atr_sl_mul / syminfo.mintick)
    else
        strategy.exit("Short Exit", "Short", stop = sl_price, limit = tp_price)

// ─── VISUALS ─────────────────────────────────────────────────────────────────
plot(ema20,  "EMA 20",  color=color.new(color.blue,   0), linewidth=1)
plot(ema50,  "EMA 50",  color=color.new(color.orange, 0), linewidth=1)
plot(ema200, "EMA 200", color=color.new(color.red,    0), linewidth=2)

plotshape(long_entry,  title="Long Signal",  style=shape.triangleup,   location=location.belowbar, color=color.new(color.green, 0), size=size.small)
plotshape(short_entry, title="Short Signal", style=shape.triangledown, location=location.abovebar, color=color.new(color.red,   0), size=size.small)

bgcolor(trend_up   ? color.new(color.green, 95) : na)
bgcolor(trend_down ? color.new(color.red,   95) : na)
