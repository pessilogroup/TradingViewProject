//@version=5
// EMA crossover alert that emits a JSON payload compatible with the Flask
// webhook server in this repo. The JSON `secret` field must match
// WEBHOOK_SECRET in server/.env.
indicator("Webhook Alert — EMA Cross", overlay=true)

fastLen = input.int(20, "Fast EMA")
slowLen = input.int(50, "Slow EMA")

fast = ta.ema(close, fastLen)
slow = ta.ema(close, slowLen)

plot(fast, color=color.aqua, title="Fast EMA")
plot(slow, color=color.orange, title="Slow EMA")

longCross  = ta.crossover(fast, slow)
shortCross = ta.crossunder(fast, slow)

// Use alertcondition() so each event becomes a discrete alert in TradingView.
// In the Alert dialog set the Message to the JSON template below
// (placeholders are interpolated server-side by TradingView).
alertcondition(longCross,  title="Long Cross",  message='{"secret":"REPLACE_WITH_WEBHOOK_SECRET","action":"buy","symbol":"{{ticker}}","price":"{{close}}","time":"{{time}}"}')
alertcondition(shortCross, title="Short Cross", message='{"secret":"REPLACE_WITH_WEBHOOK_SECRET","action":"sell","symbol":"{{ticker}}","price":"{{close}}","time":"{{time}}"}')

plotshape(longCross,  style=shape.triangleup,   location=location.belowbar, color=color.green, size=size.tiny, title="Long")
plotshape(shortCross, style=shape.triangledown, location=location.abovebar, color=color.red,   size=size.tiny, title="Short")
