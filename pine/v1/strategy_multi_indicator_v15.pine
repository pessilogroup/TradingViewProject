//@version=5
// =============================================================================
//  Multi-Indicator Strategy V1.5 — Minervini SEPA Hardened
//  Upgrade path from strategy_multi_indicator.pine (V1):
//    + Trend Template gate (8 criteria, blocks all Stage 1/3/4 entries)
//    + Long-only by default (toggle for crypto/futures shorts)
//    + Risk-based position sizing (% risk per trade, not % equity)
//    + Hard 8% stop-loss cap (Minervini non-negotiable)
//    + SMA50 trailing exit (V2 carry-over)
//    + VCP volume dry-up gate (institutional accumulation signal)
//    + Cooldown after exit (kill whipsaw)
//    + Realistic costs: 0.05% commission, no flat fee
// =============================================================================

strategy(
     title              = "Multi-Indicator Strategy V1.5 (SEPA Hardened)",
     shorttitle         = "MIS v1.5",
     overlay            = true,
     initial_capital    = 10000,
     default_qty_type   = strategy.percent_of_equity,
     default_qty_value  = 5,
     commission_type    = strategy.commission.percent,
     commission_value   = 0.05,
     slippage           = 2,
     pyramiding         = 0,
     process_orders_on_close = true,
     calc_on_every_tick = false
 )

// ─── INPUTS ───────────────────────────────────────────────────────────────────
grp_dir   = "Direction"
allow_long  = input.bool(true,  "Allow Long entries",  group=grp_dir)
allow_short = input.bool(false, "Allow Short entries (off by default — Minervini = long-only)", group=grp_dir)

grp_tt    = "Minervini Trend Template Gate"
use_tt    = input.bool(true, "Require Trend Template (8 criteria) for LONG", group=grp_tt,
     tooltip="Only enter long when stock is in confirmed Stage 2. Disables ~95% of false signals.")
rs_bench  = input.symbol("BTCUSD", "RS Benchmark Symbol", group=grp_tt,
     tooltip="Stock must outperform this benchmark over last 125 bars.")

grp_tech  = "Technical Indicators"
ema_fast  = input.int(20,  "EMA Fast",  minval=1, group=grp_tech)
ema_mid   = input.int(50,  "EMA Mid",   minval=1, group=grp_tech)
ema_slow  = input.int(200, "EMA Slow",  minval=1, group=grp_tech)
rsi_len   = input.int(14,  "RSI Length",minval=1, group=grp_tech)
rsi_ob    = input.int(70,  "RSI Overbought",       group=grp_tech)
rsi_os    = input.int(30,  "RSI Oversold",         group=grp_tech)
macd_fast = input.int(12,  "MACD Fast",            group=grp_tech)
macd_slow = input.int(26,  "MACD Slow",            group=grp_tech)
macd_sig  = input.int(9,   "MACD Signal",          group=grp_tech)
atr_len   = input.int(14,  "ATR Length",           group=grp_tech)

grp_vol   = "Volume / VCP"
vol_ma_len = input.int(50, "Volume MA Length [Minervini=50]", group=grp_vol)
vol_mult   = input.float(1.5, "Volume Breakout Multiplier", step=0.1, group=grp_vol,
     tooltip="Heavy volume on breakout = institutional accumulation. 1.5-2.0 typical.")
use_vcp    = input.bool(true, "Require recent VCP volume dry-up (last 10 bars)", group=grp_vol,
     tooltip="At least 1 bar in last 10 with volume < 50% of MA. Ensures supply absorbed before entry.")

grp_risk  = "Risk Management (Minervini SEPA)"
risk_pct      = input.float(1.0,  "Risk per trade (% equity)",   minval=0.1, maxval=5.0, step=0.1, group=grp_risk,
     tooltip="Position size = (equity × risk%) / SL distance. 0.5-2% is Minervini standard.")
atr_sl_mul    = input.float(2.0,  "ATR Stop Loss Multiplier",    step=0.1, group=grp_risk)
atr_tp_mul    = input.float(5.0,  "ATR Take Profit Multiplier",  step=0.1, group=grp_risk,
     tooltip="TP = atr_tp_mul × ATR. With atr_sl=2, atr_tp=5 → R:R = 2.5:1 (Minervini minimum).")
hard_sl_pct   = input.float(8.0,  "Hard Stop-Loss Cap (%)",      minval=2.0, maxval=15.0, step=0.5, group=grp_risk,
     tooltip="Absolute max loss per trade. Minervini = never beyond 10%, ideally 4-8%.")
use_ma_trail  = input.bool(true,  "Exit on close < SMA50 (Minervini trailing)", group=grp_risk)
cooldown_bars = input.int(3,      "Cooldown bars after exit", minval=0, maxval=50, group=grp_risk,
     tooltip="No new entry for N bars after any exit. Kills whipsaw.")

grp_ui    = "UI"
show_table = input.bool(true,  "Show Trend Template status table", group=grp_ui)
show_mas   = input.bool(true,  "Show MAs",                         group=grp_ui)

// ─── CALCULATIONS ─────────────────────────────────────────────────────────────
ema20  = ta.ema(close, ema_fast)
ema50  = ta.ema(close, ema_mid)
ema200 = ta.ema(close, ema_slow)

sma50  = ta.sma(close, 50)
sma150 = ta.sma(close, 150)
sma200 = ta.sma(close, 200)

rsi    = ta.rsi(close, rsi_len)
[macd_line, sig_line, _] = ta.macd(close, macd_fast, macd_slow, macd_sig)
macd_up   = ta.crossover(macd_line, sig_line)
macd_down = ta.crossunder(macd_line, sig_line)

atr    = ta.atr(atr_len)
vol_ma = ta.sma(volume, vol_ma_len)
heavy_vol = volume > vol_ma * vol_mult

// 52-week (250 bars) high/low for Trend Template
high52 = ta.highest(high, 250)
low52  = ta.lowest(low,   250)

// Relative Strength vs benchmark
bench   = request.security(rs_bench, timeframe.period, close, ignore_invalid_symbol=true)
stk_perf  = (close - close[125]) / close[125]
bench_perf = (bench - bench[125]) / bench[125]

// VCP dry-up: any of last 10 bars with volume < 50% of vol_ma
vol_dry_now = volume < vol_ma * 0.5
vcp_recent  = false
for i = 1 to 10
    vcp_recent := vcp_recent or vol_dry_now[i]

// ─── TREND TEMPLATE (8 CRITERIA) ──────────────────────────────────────────────
tt1 = close > sma150 and close > sma200
tt2 = sma150 > sma200
tt3 = sma200 > sma200[20]
tt4 = sma50 > sma150 and sma50 > sma200
tt5 = close > sma50
tt6 = close >= low52 * 1.30
tt7 = close >= high52 * 0.75
tt8 = stk_perf > bench_perf

trend_template_ok = tt1 and tt2 and tt3 and tt4 and tt5 and tt6 and tt7 and tt8

// ─── ENTRY LOGIC ──────────────────────────────────────────────────────────────
// Multi-indicator confluence
trend_up   = ema20 > ema50 and ema50 > ema200
trend_down = ema20 < ema50 and ema50 < ema200
rsi_long   = rsi > 50 and rsi < rsi_ob
rsi_short  = rsi < 50 and rsi > rsi_os

// Long gate: Trend Template (if enabled) + technical confluence + heavy vol + VCP
long_filter  = trend_up and rsi_long and macd_up and heavy_vol
long_filter := long_filter and (not use_tt  or trend_template_ok)
long_filter := long_filter and (not use_vcp or vcp_recent)

// Short gate (only if explicitly allowed; bypasses Trend Template — TT is long-only)
short_filter = trend_down and rsi_short and macd_down and heavy_vol

// Cooldown — block new entries N bars after any exit
var int last_exit_bar = na
in_cooldown = not na(last_exit_bar) and (bar_index - last_exit_bar) < cooldown_bars

long_entry_raw  = allow_long  and long_filter  and strategy.position_size == 0 and not in_cooldown
short_entry_raw = allow_short and short_filter and strategy.position_size == 0 and not in_cooldown

// ─── POSITION SIZING (RISK-BASED) ─────────────────────────────────────────────
// qty = (equity × risk%) / SL distance, capped by hard_sl_pct, with NaN/neg guards
sl_dist_atr  = na(atr) ? 0.0 : atr * atr_sl_mul
sl_dist_pct  = close * hard_sl_pct / 100
sl_distance  = math.max(math.min(sl_dist_atr > 0 ? sl_dist_atr : sl_dist_pct, sl_dist_pct), close * 0.005)
equity_safe  = math.max(strategy.equity, 100)
risk_capital = equity_safe * risk_pct / 100
qty_raw      = risk_capital / sl_distance
qty_long     = math.max(qty_raw, 1)
qty_short    = math.max(qty_raw, 1)
qty_valid    = not na(qty_raw) and qty_raw > 0 and qty_raw < 1e10

long_entry  = long_entry_raw  and qty_valid
short_entry = short_entry_raw and qty_valid

// ─── ENTRIES ──────────────────────────────────────────────────────────────────
if long_entry
    strategy.entry("Long",  strategy.long,  qty=qty_long,
         alert_message='{"action":"buy","symbol":"' + syminfo.ticker + '","price":"' + str.tostring(close) + '"}')

if short_entry
    strategy.entry("Short", strategy.short, qty=qty_short,
         alert_message='{"action":"sell","symbol":"' + syminfo.ticker + '","price":"' + str.tostring(close) + '"}')

// ─── EXITS ────────────────────────────────────────────────────────────────────
var float entry_atr = na
if long_entry or short_entry
    entry_atr := atr

if strategy.position_size > 0
    avg = strategy.position_avg_price
    sl  = math.max(avg - entry_atr * atr_sl_mul, avg * (1 - hard_sl_pct / 100))
    tp  = avg + entry_atr * atr_tp_mul
    if use_ma_trail and close < sma50
        strategy.close("Long", comment="MA50 trail")
    else
        strategy.exit("Long Exit", "Long", stop=sl, limit=tp, comment_loss="SL hit", comment_profit="TP hit")

if strategy.position_size < 0
    avg = strategy.position_avg_price
    sl  = math.min(avg + entry_atr * atr_sl_mul, avg * (1 + hard_sl_pct / 100))
    tp  = avg - entry_atr * atr_tp_mul
    strategy.exit("Short Exit", "Short", stop=sl, limit=tp, comment_loss="SL hit", comment_profit="TP hit")

// Track exit bar for cooldown
if strategy.position_size == 0 and strategy.position_size[1] != 0
    last_exit_bar := bar_index

// ─── VISUALS ──────────────────────────────────────────────────────────────────
plot(show_mas ? sma50  : na, "SMA 50",  color.blue,   linewidth=1)
plot(show_mas ? sma150 : na, "SMA 150", color.orange, linewidth=1)
plot(show_mas ? sma200 : na, "SMA 200", color.red,    linewidth=2)

plotshape(long_entry,  "Long Signal",  shape.triangleup,   location.belowbar, color.new(color.green, 0), size=size.small)
plotshape(short_entry, "Short Signal", shape.triangledown, location.abovebar, color.new(color.red,   0), size=size.small)

barcolor(use_tt and trend_template_ok ? color.new(color.green, 80) : na, title="Trend Template")

// ─── STATUS TABLE ─────────────────────────────────────────────────────────────
var table tt_table = table.new(position.bottom_right, 2, 10, border_width=1)

if show_table and barstate.islast
    table.cell(tt_table, 0, 0, "Trend Template (8)", bgcolor=color.new(color.gray, 30), text_color=color.white)
    table.cell(tt_table, 1, 0, trend_template_ok ? "PASS" : "FAIL",
         bgcolor=trend_template_ok ? color.new(color.green, 40) : color.new(color.red, 40),
         text_color=color.white)
    bg_ok(b) => b ? color.new(color.green, 70) : color.new(color.red, 70)
    mark(b)  => b ? "✓" : "✗"
    table.cell(tt_table, 0, 1, "1. Price > SMA150 & 200")
    table.cell(tt_table, 1, 1, mark(tt1), bgcolor=bg_ok(tt1))
    table.cell(tt_table, 0, 2, "2. SMA150 > SMA200")
    table.cell(tt_table, 1, 2, mark(tt2), bgcolor=bg_ok(tt2))
    table.cell(tt_table, 0, 3, "3. SMA200 sloping up")
    table.cell(tt_table, 1, 3, mark(tt3), bgcolor=bg_ok(tt3))
    table.cell(tt_table, 0, 4, "4. SMA50 > SMA150 & 200")
    table.cell(tt_table, 1, 4, mark(tt4), bgcolor=bg_ok(tt4))
    table.cell(tt_table, 0, 5, "5. Price > SMA50")
    table.cell(tt_table, 1, 5, mark(tt5), bgcolor=bg_ok(tt5))
    table.cell(tt_table, 0, 6, "6. ≥30% above 52w low")
    table.cell(tt_table, 1, 6, mark(tt6), bgcolor=bg_ok(tt6))
    table.cell(tt_table, 0, 7, "7. Within 25% of 52w high")
    table.cell(tt_table, 1, 7, mark(tt7), bgcolor=bg_ok(tt7))
    table.cell(tt_table, 0, 8, "8. RS > Benchmark")
    table.cell(tt_table, 1, 8, mark(tt8), bgcolor=bg_ok(tt8))
    table.cell(tt_table, 0, 9, "Cooldown active?")
    table.cell(tt_table, 1, 9, in_cooldown ? "YES" : "no",
         bgcolor=in_cooldown ? color.new(color.orange, 50) : color.new(color.gray, 70))
