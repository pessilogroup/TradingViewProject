//@version=5
indicator("indicator_Mark Minervini Trend Template & VCP v1.000", shorttitle="indicator_Minervini TT v1.000", overlay=true)

// ================================================================================================= //
// INPUTS & SETTINGS
// ================================================================================================= //
grp_ma = "Moving Averages"
show_mas = input.bool(true, title="Hiển thị các đường MA", group=grp_ma)

grp_rs = "Relative Strength (RS) Settings"
rs_option = input.string("VNINDEX (Thị trường VN)", title="Chọn Benchmark Market", options=["SPY (Thị trường Mỹ)", "VNINDEX (Thị trường VN)", "BTCUSD (Crypto)"], group=grp_rs)

grp_ui = "UI Settings"
show_table = input.bool(true, title="Hiển thị bảng trạng thái (Table)", group=grp_ui)

// Determine Benchmark Ticker
string benchmark_ticker = "VNINDEX" // Default fallback
if rs_option == "SPY (Thị trường Mỹ)"
    benchmark_ticker := "SPY"
else if rs_option == "VNINDEX (Thị trường VN)"
    benchmark_ticker := "VNINDEX"
else if rs_option == "BTCUSD (Crypto)"
    benchmark_ticker := "BTCUSD"

// ================================================================================================= //
// DATA CALCULATIONS
// ================================================================================================= //

// 1. Moving Averages
sma50 = ta.sma(close, 50)
sma150 = ta.sma(close, 150)
sma200 = ta.sma(close, 200)

// 2. 52-Week High & Low (approximated as 250 trading days)
high52 = ta.highest(high, 250)
low52 = ta.lowest(low, 250)

// 3. Relative Strength (Outperformance over the last 125 days / 6 months)
bench_close = request.security(benchmark_ticker, timeframe.period, close)
stock_perf = (close - close[125]) / close[125]
bench_perf = (bench_close - bench_close[125]) / bench_close[125]

// ================================================================================================= //
// TREND TEMPLATE CONDITIONS (8 Rules)
// ================================================================================================= //

// Tiêu chí 1: Giá hiện tại > SMA 150 và SMA 200
cond1 = close > sma150 and close > sma200

// Tiêu chí 2: SMA 150 > SMA 200
cond2 = sma150 > sma200

// Tiêu chí 3: SMA 200 đang có xu hướng dốc lên (khoảng 1 tháng / 20 phiên)
cond3 = sma200 > sma200[20]

// Tiêu chí 4: SMA 50 > SMA 150 và SMA 200
cond4 = sma50 > sma150 and sma50 > sma200

// Tiêu chí 5: Giá hiện tại > SMA 50
cond5 = close > sma50

// Tiêu chí 6: Giá hiện tại cao hơn ít nhất 30% so với đáy 52 tuần
cond6 = close >= (low52 * 1.30)

// Tiêu chí 7: Giá hiện tại cách đỉnh 52 tuần không quá 25% (>= 75% đỉnh)
cond7 = close >= (high52 * 0.75)

// Tiêu chí 8: Sức mạnh tương đối cao (Cổ phiếu phải khỏe hơn Benchmark)
cond8 = stock_perf > bench_perf

// TỔNG HỢP:
trend_template_met = cond1 and cond2 and cond3 and cond4 and cond5 and cond6 and cond7 and cond8

// ================================================================================================= //
// VCP / VOLUME DRY-UP DETECTOR
// ================================================================================================= //
vol_sma = ta.sma(volume, 50)
// Thanh khoản cạn kiệt: Volume hiện tại thấp hơn 50% so với trung bình 50 phiên
vol_dry_up = volume < (vol_sma * 0.5)

// Biên độ thu hẹp (Tightness): Spread giữa High/Low của nến < 50% so với ATR 14
atr = ta.atr(14)
tight_range = (high - low) < (atr * 0.5)

vcp_signal = vol_dry_up and tight_range

// ================================================================================================= //
// VISUALS & PLOTS
// ================================================================================================= //

// Plot MAs
plot(show_mas ? sma50 : na, color=color.blue, title="SMA 50", linewidth=1)
plot(show_mas ? sma150 : na, color=color.orange, title="SMA 150", linewidth=1)
plot(show_mas ? sma200 : na, color=color.red, title="SMA 200", linewidth=2)

// Plot 52-Week High/Low lines (optional, kept subtle)
plot(high52, color=color.new(color.gray, 70), title="52W High", style=plot.style_linebr)
plot(low52, color=color.new(color.gray, 70), title="52W Low", style=plot.style_linebr)

// Đổi màu nến khi thỏa mãn toàn bộ Trend Template
barcolor(trend_template_met ? color.new(color.green, 0) : na, title="Trend Template Color")

// Đánh dấu VCP/Dry-up Signal
plotshape(series=vcp_signal and trend_template_met, title="VCP Dry-up Setup", style=shape.triangleup, location=location.belowbar, color=color.new(color.fuchsia, 0), size=size.small, text="VCP", textcolor=color.fuchsia)

// ================================================================================================= //
// STATUS TABLE
// ================================================================================================= //
var table statusTable = table.new(position.bottom_right, 2, 9, border_width=1)

if show_table and barstate.islast
    table.cell(statusTable, 0, 0, "Tiêu chuẩn Trend Template", bgcolor=color.new(color.gray, 30), text_color=color.white)
    table.cell(statusTable, 1, 0, "Trạng thái", bgcolor=color.new(color.gray, 30), text_color=color.white)
    
    table.cell(statusTable, 0, 1, "1. Giá > SMA 150 & 200")
    table.cell(statusTable, 1, 1, cond1 ? "ĐẠT" : "CHƯA", bgcolor=cond1 ? color.new(color.green, 70) : color.new(color.red, 70))
    
    table.cell(statusTable, 0, 2, "2. SMA 150 > SMA 200")
    table.cell(statusTable, 1, 2, cond2 ? "ĐẠT" : "CHƯA", bgcolor=cond2 ? color.new(color.green, 70) : color.new(color.red, 70))
    
    table.cell(statusTable, 0, 3, "3. SMA 200 dốc lên (20 phiên)")
    table.cell(statusTable, 1, 3, cond3 ? "ĐẠT" : "CHƯA", bgcolor=cond3 ? color.new(color.green, 70) : color.new(color.red, 70))
    
    table.cell(statusTable, 0, 4, "4. SMA 50 > SMA 150 & 200")
    table.cell(statusTable, 1, 4, cond4 ? "ĐẠT" : "CHƯA", bgcolor=cond4 ? color.new(color.green, 70) : color.new(color.red, 70))
    
    table.cell(statusTable, 0, 5, "5. Giá > SMA 50")
    table.cell(statusTable, 1, 5, cond5 ? "ĐẠT" : "CHƯA", bgcolor=cond5 ? color.new(color.green, 70) : color.new(color.red, 70))
    
    table.cell(statusTable, 0, 6, "6. Giá cách đáy 52W > 30%")
    table.cell(statusTable, 1, 6, cond6 ? "ĐẠT" : "CHƯA", bgcolor=cond6 ? color.new(color.green, 70) : color.new(color.red, 70))
    
    table.cell(statusTable, 0, 7, "7. Giá cách đỉnh 52W < 25%")
    table.cell(statusTable, 1, 7, cond7 ? "ĐẠT" : "CHƯA", bgcolor=cond7 ? color.new(color.green, 70) : color.new(color.red, 70))
    
    table.cell(statusTable, 0, 8, "8. Cổ phiếu mạnh hơn Benchmark")
    table.cell(statusTable, 1, 8, cond8 ? "ĐẠT" : "CHƯA", bgcolor=cond8 ? color.new(color.green, 70) : color.new(color.red, 70))
