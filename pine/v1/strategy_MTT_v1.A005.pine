// (c) TradingViewProject
// Strategy A.005 — Long Only
// Khi strategy_mtt_lib được publish, đổi inline helpers thành: import TradingViewProject/strategy_mtt_lib/1 as mtt
//
//@version=5
strategy("strategy_MTT_v1.A005 (Long Only)",
     shorttitle="A.005 L",
     overlay=true,
     initial_capital=100000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=10,
     commission_type=strategy.commission.percent,
     commission_value=0.075,
     slippage=2,
     pyramiding=0,
     calc_on_every_tick=false,
     process_orders_on_close=true)

// ----- INPUTS -----
grp_p = "Trading Profile"
profile  = input.string("Futures", "Profile", options=["Spot","Margin","Futures"], group=grp_p)
override_qty = input.bool(false, "Override profile qty %", group=grp_p)
manual_qty   = input.float(10.0, "Manual qty %", minval=1.0, maxval=100.0, group=grp_p)

grp_ma = "MA Settings (V1.005-b winning combo)"
ma_type  = input.string("EMA", "MA Type", options=["SMA","EMA","WMA","HMA","DEMA","TEMA"], group=grp_ma)
fast_len = input.int(20,  "Fast",   minval=5,  group=grp_ma)
med_len  = input.int(50,  "Medium", minval=10, group=grp_ma)
slow_len = input.int(100, "Slow",   minval=20, group=grp_ma)

// ----- MA helper -----
ma(t, l) =>
    switch t
        "SMA"  => ta.sma(close, l)
        "EMA"  => ta.ema(close, l)
        "WMA"  => ta.wma(close, l)
        "HMA"  => ta.hma(close, l)
        "DEMA" => 2 * ta.ema(close, l) - ta.ema(ta.ema(close, l), l)
        "TEMA" => 3 * (ta.ema(close, l) - ta.ema(ta.ema(close, l), l)) + ta.ema(ta.ema(ta.ema(close, l), l), l)
        =>        ta.sma(close, l)

mf = ma(ma_type, fast_len)
mm = ma(ma_type, med_len)
ms = ma(ma_type, slow_len)

bull = mf > mm and mm > ms
bull_start = bull and not bull[1]
bull_end   = not bull and bull[1]

// V1.005 profile qty (giảm so với V1.A004)
spot_pct    = 10.0
margin_pct  = 20.0
futures_pct = 10.0
qty_pct = override_qty ? manual_qty : (profile == "Spot" ? spot_pct : profile == "Margin" ? margin_pct : futures_pct)
qc = (strategy.equity * qty_pct / 100.0) / close

if bull_start
    strategy.entry("LONG", strategy.long, qty=qc, comment="Bull Start")
if bull_end
    strategy.close("LONG", comment="Bull End")

// Visual
p_f = plot(mf, color=color.blue,   title="Fast")
p_m = plot(mm, color=color.orange, title="Medium")
p_s = plot(ms, color=color.red,    title="Slow", linewidth=2)
fill(p_f, p_s, color=bull ? color.new(color.green, 80) : na, title="Bull Zone")

plotshape(bull_start, title="L", style=shape.triangleup, location=location.belowbar, color=color.new(color.green,0),  size=size.tiny, text="L")
plotshape(bull_end,   title="x", style=shape.xcross,     location=location.abovebar, color=color.new(color.green,30), size=size.tiny)
