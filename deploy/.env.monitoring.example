# ════════════════════════════════════════════════════════════════
# deploy/.env.monitoring — V2 Monitoring Bootstrap Variables
# Copy sang .env.monitoring.local và điền giá trị thật
#
# Usage (chạy trên SERVER A):
#   source .env.monitoring.local
#   sudo ./setup_monitoring.sh
# ════════════════════════════════════════════════════════════════

# ── UptimeRobot (#14) ─────────────────────────────────────────
# Lấy tại: https://uptimerobot.com/dashboard#api → "Main API Key"
UPTIMEROBOT_API_KEY=ur_mainApiKey_xxxxx

# IP công khai hoặc domain của SERVER A
# Nếu dùng Cloudflare Tunnel → dùng subdomain của bạn
SERVER_A_PUBLIC_IP=YOUR_SERVER_A_IP_OR_DOMAIN

# ── Telegram (dùng để test alert thủ công) ───────────────────
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# ── Cloudflare (optional) ─────────────────────────────────────
# Chỉ cần nếu muốn setup Cloudflare Health Checks qua script
CF_API_TOKEN=
CF_ZONE_ID=
