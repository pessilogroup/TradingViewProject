# ════════════════════════════════════════════════════════════════
# Production Environment Template — Minervini AI Trading Bot
# Sprint 7.3: Docker Deploy
# ════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your secrets:
#   cp .env.production .env
# ════════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=5000
DEBUG=false

# ── Security ─────────────────────────────────────────────────────
# REQUIRED: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=CHANGE_ME_GENERATE_RANDOM_HEX

# Dashboard API token (bearer auth for /api/* endpoints)
DASHBOARD_TOKEN=CHANGE_ME_GENERATE_RANDOM_TOKEN

# TradingView IP whitelist (enable in production)
ENABLE_IP_WHITELIST=true

# ── Database ─────────────────────────────────────────────────────
# Paths inside container (mapped to Docker volumes)
DB_PATH=/app/data/trades.db
LOG_FILE=/app/logs/trades.log

# ── Binance API ──────────────────────────────────────────────────
# Get keys at: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
# IMPORTANT: Set to false ONLY when ready for real trading
BINANCE_DRY_RUN=true

# ── Risk Management (Minervini SEPA) ─────────────────────────────
RISK_PER_TRADE=0.02
STOP_LOSS_PCT=0.08
TAKE_PROFIT_PCT=0.20

# ── Notifications ────────────────────────────────────────────────
# Telegram Bot: create via @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Telegram interactive bot (commands: /brief, /scan, /balance, etc.)
TELEGRAM_BOT_ENABLED=true

# Discord webhook (optional)
DISCORD_WEBHOOK_URL=

# ── RAG / Knowledge Base ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RAG_ENABLED=true
RAG_TOP_K=3

# Paths inside container
KNOWLEDGE_DIR=/app/knowledge/trading_wizard/chunks
CHROMA_DB_PATH=/app/data/chroma_db

# ── MCP (TradingView Desktop) ────────────────────────────────────
# Disable in Docker (TradingView Desktop runs on host, not in container)
MCP_ENABLED=false
MCP_CDP_PORT=9222

# ── Morning Brief ────────────────────────────────────────────────
BRIEF_ENABLED=false
BRIEF_CRON_TIME=07:00

# ── Watchlist ────────────────────────────────────────────────────
WATCHLIST_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
