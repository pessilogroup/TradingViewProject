         print("[OK] Test 2: Background Semantic Ingestion verified!")
 
+    def test_angati_version_mismatch_warning(self):
+        """Verify version check prints warning to stderr on mismatch."""
+        import tempfile
+        import io
+        from contextlib import redirect_stderr
+        
+        # Create temp files with mismatching content
+        with tempfile.NamedTemporaryFile(delete=False) as local_f, \
+             tempfile.NamedTemporaryFile(delete=False) as brain_f:
+            
+            try:
+                local_f.write(b"local_version_data_123")
+                local_f.flush()
+                brain_f.write(b"brain_version_data_456")
+                brain_f.flush()
+                
+                local_f.close()
+                brain_f.close()
+                
+                # Mock environment variables
+                os.environ["ANGATI_LOCAL_EXE_PATH"] = local_f.name
+                os.environ["ANGATI_BRAIN_EXE_PATH"] = brain_f.name
+                
+                # Capture stderr
+                f = io.StringIO()
+                with redirect_stderr(f):
+                    t = hook_service.check_angati_version_async()
+                    t.join(timeout=2.0)
+                
+                output = f.getvalue()
+                self.assertIn("WARNING: Local angati.exe version mismatch detected!", output)
+                print("[OK] Test 3: Version mismatch warning verified!")
+                
+            finally:
+                os.unlink(local_f.name)
+                os.unlink(brain_f.name)
+                os.environ.pop("ANGATI_LOCAL_EXE_PATH", None)
+                os.environ.pop("ANGATI_BRAIN_EXE_PATH", None)
+
+    def test_angati_version_matching(self):
+        """Verify version check prints no warning when hashes match."""
+        import tempfile
+        import io
+        from contextlib import redirect_stderr
+        
+        with tempfile.NamedTemporaryFile(delete=False) as local_f, \
+             tempfile.NamedTemporaryFile(delete=False) as brain_f:
+            
+            try:
+                content = b"identical_binary_content"
+                local_f.write(content)
+                local_f.flush()
+                brain_f.write(content)
+                brain_f.flush()
+                
+                local_f.close()
+                brain_f.close()
+                
+                os.environ["ANGATI_LOCAL_EXE_PATH"] = local_f.name
+                os.environ["ANGATI_BRAIN_EXE_PATH"] = brain_f.name
+                
+                f = io.StringIO()
+                with redirect_stderr(f):
+                    t = hook_service.check_angati_version_async()
+                    t.join(timeout=2.0)
+                
+                output = f.getvalue()
+                self.assertNotIn("WARNING: Local angati.exe version mismatch detected!", output)
+                print("[OK] Test 4: Version match no-warning verified!")
+                
+            finally:
+                os.unlink(local_f.name)
+                os.unlink(brain_f.name)
+                os.environ.pop("ANGATI_LOCAL_EXE_PATH", None)
+                os.environ.pop("ANGATI_BRAIN_EXE_PATH", None)
+
+    def test_angati_version_missing_files(self):
+        """Verify version check handles missing files gracefully."""
+        import io
+        from contextlib import redirect_stderr
+        
+        os.environ["ANGATI_LOCAL_EXE_PATH"] = "nonexistent_local_file.exe"
+        os.environ["ANGATI_BRAIN_EXE_PATH"] = "nonexistent_brain_file.exe"
+        
+        f = io.StringIO()
+        try:
+            with redirect_stderr(f):
+                t = hook_service.check_angati_version_async()
+                t.join(timeout=2.0)
+            
+            output = f.getvalue()
+            self.assertEqual(output, "")
+            print("[OK] Test 5: Graceful handle of missing files verified!")
+        finally:
+            os.environ.pop("ANGATI_LOCAL_EXE_PATH", None)
+            os.environ.pop("ANGATI_BRAIN_EXE_PATH", None)
