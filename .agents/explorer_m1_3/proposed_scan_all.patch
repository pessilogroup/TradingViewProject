+
+async def cmd_scan_all(update, context):
+    """Scan all watchlist symbols in background and send the results to avoid polling timeouts."""
+    chat_id = update.effective_chat.id
+    await update.message.reply_text(
+        "🔄 <b>Bắt đầu quét toàn bộ watchlist trong background...</b>\n"
+        "Tiến trình này có thể tốn vài phút. Tôi sẽ gửi thông báo kết quả khi quét xong.",
+        parse_mode="HTML"
+    )
+    asyncio.create_task(run_scan_all_background(chat_id))
+
+
+async def run_scan_all_background(chat_id: int):
+    """Background task runner to perform watchlist scan and broadcast top setups."""
+    try:
+        from watchlist import get_watchlist
+        from analysis import scan_symbols
+        import config
+        from datetime import datetime
+        from notifier import sanitize_for_telegram_html
+
+        symbols = get_watchlist()
+        if not symbols:
+            sender = get_sender()
+            if sender:
+                await sender.send_message("⚠️ Watchlist trống. Vui lòng thêm symbol bằng /add.")
+            return
+
+        mcp = None
+        if config.MCP_ENABLED:
+            try:
+                from mcp_client import get_mcp_client
+                mcp = get_mcp_client()
+            except Exception as e:
+                log.warning(f"MCP client load failed in run_scan_all_background: {e}")
+
+        results = await scan_symbols(symbols, mcp)
+        if not results:
+            sender = get_sender()
+            if sender:
+                await sender.send_message("⚠️ Không nhận được kết quả quét nào.")
+            return
+
+        top_setups = []
+        for r in results:
+            score = r.trend_template.score if r.trend_template else 0
+            vcp_detected = r.vcp.detected if r.vcp else False
+            if score >= 6 or vcp_detected:
+                top_setups.append(r)
+
+        lines = [
+            "📊 <b>KẾT QUẢ QUÉT TOÀN BỘ WATCHLIST (TOP SETUPS)</b>\n",
+            f"⏰ Thời gian: <code>{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}</code>",
+            f"📋 Tổng số mã đã quét: <b>{len(results)}</b>",
+            f"🎯 Setup nổi bật (TT ≥ 6/8 hoặc VCP): <b>{len(top_setups)}</b>\n",
+        ]
+
+        if not top_setups:
+            lines.append("<i>Không tìm thấy cơ hội giao dịch nào đáp ứng tiêu chí.</i>")
+        else:
+            lines.append("<pre>")
+            lines.append(f"{'Symbol':<10} {'Price':>10} {'TT':>4} {'VCP':>4}")
+            lines.append("─" * 32)
+            for r in top_setups:
+                score = r.trend_template.score if r.trend_template else 0
+                vcp_flag = "⭐" if r.vcp and r.vcp.detected else "❌"
+                price = r.price
+                price_str = f"{price:,.2f}" if price >= 1 else f"{price:.4f}"
+                lines.append(f"{r.symbol:<10} {price_str:>10} {score}/8  {vcp_flag:<3}")
+            lines.append("</pre>\n")
+
+            lines.append("🔍 <b>Chi tiết Setups:</b>\n")
+            for r in top_setups:
+                score = r.trend_template.score if r.trend_template else 0
+                stage = r.trend_template.stage if r.trend_template else "Unknown"
+                vcp_flag = "⭐ VCP" if r.vcp and r.vcp.detected else "Trend Template"
+                vol_ratio = r.vcp.volume_ratio if r.vcp else 0
+                lines.append(
+                    f"• <b>{r.symbol}</b> - {stage} ({score}/8)\n"
+                    f"  Giá: <code>{r.price}</code> | Vol: <code>{vol_ratio*100:.0f}%</code> avg\n"
+                    f"  Ghi chú: <i>{r.vcp.note if r.vcp else 'N/A'}</i>\n"
+                )
+
+        text = sanitize_for_telegram_html("\n".join(lines))
+        
+        app = get_application()
+        if app:
+            await app.bot.send_message(chat_id=chat_id, text=text, parse_mode="HTML")
+            sender = get_sender()
+            if sender:
+                for c_id in config.TELEGRAM_CHAT_IDS:
+                    if int(c_id) != chat_id:
+                        try:
+                            await app.bot.send_message(chat_id=c_id, text=text, parse_mode="HTML")
+                        except Exception as e:
+                            log.error(f"Failed to broadcast setup results to {c_id}: {e}")
+    except Exception as e:
+        log.error(f"Error running background scan: {e}", exc_info=True)
+        app = get_application()
+        if app:
+            try:
+                await app.bot.send_message(
+                    chat_id=chat_id,
+                    text=f"❌ <b>Quét background gặp lỗi:</b>\n<code>{e}</code>",
+                    parse_mode="HTML"
+                )
+            except Exception:
+                pass
 
 
 
