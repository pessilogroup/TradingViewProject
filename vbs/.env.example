PORT=5000
HOST=0.0.0.0

# The secret token to authenticate TradingView webhook signals and Local Bot pulling.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
BUFFER_SECRET=YOUR_32_BYTE_HEX_SECRET_HERE

# Time to Live for each signal in hours (e.g. 4.0 = 4 hours)
SIGNAL_TTL_HOURS=4.0

# Timeout in minutes for local bot to acknowledge a signal before it is re-queued
DISPATCH_TIMEOUT_MINUTES=5.0

# Max queue size of pending signals (0 = unlimited)
MAX_QUEUE_SIZE=1000

# Telegram Bot integration (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Cron settings
CLEANUP_INTERVAL_MINUTES=15
AUDIT_RETENTION_DAYS=7

# SQLite path
DB_PATH=data/signal_queue.db
